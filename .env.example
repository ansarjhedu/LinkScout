# MaxOpp Intelligence Scraper — Browser-Native React Environment Variables
# All processing runs 100% client-side inside the browser. No backend server required.

# Legacy single-proxy URL (fetchProxy now auto-rotates through multiple providers)
VITE_CORS_PROXY_URL=https://api.allorigins.win/raw?url=

# Maximum page fetch limit (increased for product/collection discovery)
VITE_MAX_CRAWL_PAGES=1500

# Minimum rate limiting delay (in milliseconds) enforced between sequential requests
VITE_CRAWL_RATE_LIMIT_MS=150

# Parallel fetch concurrency (lower = more reliable through public proxies)
VITE_CRAWL_CONCURRENCY=4

# Global dashboard application metadata title
VITE_APP_TITLE=MaxOpp Intelligence Crawler
